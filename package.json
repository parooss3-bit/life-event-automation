{
  "name": "life-event-automation",
  "version": "1.0.0",
  "description": "Life Event Automation Platform - Birthday and Event Reminders",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "npm run prisma:generate && tsc",
    "build:client": "cd client && npm install && npm run build",
    "start": "npm run prisma:migrate:prod || true && node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "birthday",
    "reminders",
    "events",
    "automation",
    "personal-crm"
  ],
  "author": "MomentRemind",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "@sendgrid/mail": "^8.1.0",
    "axios": "^1.6.5",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.1.2",
    "pg": "^8.11.3",
    "prisma": "^5.8.0",
    "stripe": "^14.10.0",
    "winston": "^3.11.0",
    "express-static-gzip": "^2.1.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "@types/express-static-gzip": "^2.1.1"
  }
}
